# =====================================================================
# VienaPets — Variables de entorno (plantilla)
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local NUNCA se commitea (ver .gitignore).
# =====================================================================

# ---------------------------------------------------------------------
# Supabase (Sprint 2)
# Región: Frankfurt EU
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo en server (API routes). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Stripe (Sprint 3)
# Stripe Checkout hosted + Stripe Tax + Stripe Invoicing
# ---------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Firma del endpoint /api/webhook (Sprint 4). Solo server. Lo da Stripe al
# crear el webhook (Dashboard → Developers → Webhooks → Signing secret).
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------
# Brevo — email transaccional (sprint posterior)
# ---------------------------------------------------------------------
BREVO_API_KEY=

# ---------------------------------------------------------------------
# Configuración del sitio
# ---------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
